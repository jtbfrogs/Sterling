# ══════════════════════════════════════════════════════════════════════════════
#  STERLING — Configuration
#  All tuneable values live here. Restart Sterling after any change.
#  Secrets (API keys) are gitignored — never commit this file.
# ══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# Identity & spoken responses
# ─────────────────────────────────────────────────────────────────────────────
sterling:
  name: "Sterling"
  startup_message:  "Sterling online, how can I assist you?"
  shutdown_message: "Understood. Powering down. Goodbye."

  # Spoken when the wake word fires and Sterling is ready to listen
  ack_message: "Yes?"

  # Spoken when the conversation times out and Sterling goes back to sleep
  sleep_message: "Going quiet. Say my name when you need me."

  # Spoken after "clear memory" command
  memory_clear_message: "Memory cleared. I've forgotten our previous conversation. Starting fresh."
  fact_saved_message: "Got it. I'll remember that."
  forget_facts_message: "Done. I've cleared what I knew about you."

  # Template for session-status response  ({duration} and {turns} are filled in)
  session_duration_response: "We've been talking for {duration}, across {turns} exchanges."

  # Spoken by the presence monitor when you walk in (presence.greet_on_enter: true)
  greet_on_enter_message: "Welcome back."


# ─────────────────────────────────────────────────────────────────────────────
# Command trigger phrases  (substring match, case-insensitive)
# Add your own phrases to any list — Sterling will react to all of them.
# ─────────────────────────────────────────────────────────────────────────────
commands:

  # Hard shutdown — kills the process
  shutdown:
    - "shut down"
    - "shutdown"
    - "power off"
    - "go offline"

  # Graceful wind-down — LLM says goodbye first, then returns to wake-word mode
  winddown:
    - "i'm done"
    - "im done"
    - "goodbye"
    - "talk later"

  # Wipe the in-session conversation window (JSON + ChromaDB NOT wiped)
  memory_clear:
    - "clear memory"
    - "clear your memory"
    - "reset conversation"
    - "start fresh"

  # Wipe durable facts (things you asked Sterling to remember)
  forget_facts:
    - "forget what you know about me"
    - "forget my facts"
    - "delete what you know about me"
    - "forget everything about me"

  # Ask how long the session has been running
  session_status:
    - "how long have we been talking"
    - "session duration"
    - "how long have you been running"

  # Speak a summary of which subsystems are online
  diagnostics:
    - "run diagnostics"
    - "system status"
    - "what's working"
    - "what is working"
    - "systems check"
    - "your status"


# ─────────────────────────────────────────────────────────────────────────────
# Context-injection trigger phrases  (substring match, case-insensitive)
# These route the question through the matching context injector before
# the LLM responds — so Sterling answers with real data, not guesses.
# ─────────────────────────────────────────────────────────────────────────────
queries:

  # Camera / vision — injects live scene description
  vision:
    - "what do you see"
    - "what can you see"
    - "what are you seeing"
    - "what's in front of you"
    - "what is in front of you"
    - "look at this"
    - "what is this"
    - "what are you looking at"
    - "describe what you see"
    - "describe the room"
    - "describe the scene"
    - "who's in the room"
    - "who is in the room"
    - "who do you see"
    - "who's there"
    - "who is there"
    - "anyone in the room"
    - "can you see me"
    - "do you see me"
    - "what am i holding"
    - "what's in my hand"
    - "what is in my hand"
    - "what am i carrying"
    - "what do i have in my hand"
    - "what's that in my hand"
    - "what am i doing"
    - "what's going on"
    - "what do you notice"
    - "anything interesting"

  # Time / date — injects current local datetime
  time:
    - "what time"
    - "what's the time"
    - "do you know the time"
    - "what's today"
    - "what day is it"
    - "what's the date"
    - "today's date"
    - "what is today"
    - "day of the week"
    - "what year"
    - "what month"

  # Weather — injects live wttr.in data for the configured location
  weather:
    - "weather"
    - "temperature"
    - "how hot"
    - "how cold"
    - "how warm"
    - "raining"
    - "snowing"
    - "outside"
    - "bring a jacket"
    - "what's it like"
    - "forecast"

  # Object tracking — injects last-seen position from object_tracker.json
  tracking:
    - "where's my"
    - "where is my"
    - "where did i put"
    - "have you seen my"
    - "seen my"
    - "find my"
    - "where did i leave"
    - "where are my"


# ─────────────────────────────────────────────────────────────────────────────
# Wake-word detection
# ─────────────────────────────────────────────────────────────────────────────
wake_word:
  phrases:
    - "hey sterling"    # most reliable — two distinct words
    - "sterling"        # solid single-word trigger
    - "ster"            # short variant
  model_size: "tiny"    # tiny (fast, ~150 MB) | base (more accurate, ~290 MB)
  energy_threshold: 500 # RMS amplitude — raise if background noise false-triggers
  silence_duration: 0.6 # seconds of silence after speech before transcription fires
  max_buffer_seconds: 2.5


# ─────────────────────────────────────────────────────────────────────────────
# LLM  (Ollama)
# ─────────────────────────────────────────────────────────────────────────────
llm:
  model: "llama3.2:3b"
  base_url: "http://localhost:11434"
  temperature: 0.7
  context_window: 4096
  stream: true
  max_tokens: 150   # 128=brief | 150=casual | 256=detailed | 512+=long-form


# ─────────────────────────────────────────────────────────────────────────────
# Speech-to-text  (Faster-Whisper)
# ─────────────────────────────────────────────────────────────────────────────
stt:
  model: "base"       # tiny | base | small  (base recommended for M1 8 GB)
  language: "en"
  device: "cpu"       # cpu (int8 on M1 is fast)
  compute_type: "int8"


# ─────────────────────────────────────────────────────────────────────────────
# Text-to-speech  (Edge-TTS + macOS say fallback)
# ─────────────────────────────────────────────────────────────────────────────
tts:
  voice: "en-GB-RyanNeural"  # British male — Jarvis feel. Run `edge-tts --list-voices` for options.
  rate: "+5%"                # Speed: -50% to +100%
  pitch: "-5Hz"              # Pitch: -50Hz to +50Hz  (lower = deeper)
  fallback_voice: "Alex"     # macOS `say` voice used when offline

  # Minimum characters to buffer before sending a chunk to synthesis.
  # Lower = first words arrive faster.  Higher = fewer HTTP round-trips, smoother audio.
  stream_chunk_chars: 80


# ─────────────────────────────────────────────────────────────────────────────
# Audio / microphone
# ─────────────────────────────────────────────────────────────────────────────
audio:
  sample_rate: 16000
  channels: 1
  chunk_size: 1024
  silence_threshold: 500      # RMS energy cutoff — raise if mic is noisy
  silence_duration: 1.0       # seconds of silence before recording stops
  max_recording_seconds: 30   # hard safety cap on recording length


# ─────────────────────────────────────────────────────────────────────────────
# Conversation loop
# ─────────────────────────────────────────────────────────────────────────────
conversation:
  timeout: 20            # seconds of silence before returning to wake-word mode
  interrupt_grace: 0.8   # seconds before barge-in activates while Sterling speaks


# ─────────────────────────────────────────────────────────────────────────────
# Memory
# ─────────────────────────────────────────────────────────────────────────────
memory:
  max_history: 12         # turns kept in the active session window
  persist: true           # write every message to memory_file with timestamps
  memory_file: "memory.json"
  recall_turns: 2         # turns anchored from last session for continuity
  recall_results: 3       # relevant past exchanges injected via keyword recall
  facts_file: "facts.json"  # durable facts: "remember that I like jazz"
  # ChromaDB is optional and unavailable on Python 3.14 (native bindings missing).
  # Keyword recall + facts store handle long-term memory with no native deps.
  chroma_enabled: false
  chroma_path: ".chroma"
  chroma_results: 3


# ─────────────────────────────────────────────────────────────────────────────
# Weather
# ─────────────────────────────────────────────────────────────────────────────
weather:
  location: "Superior, Colorado"   # default — you can also say "weather in Denver" on the fly


# ─────────────────────────────────────────────────────────────────────────────
# Govee smart lights
# ─────────────────────────────────────────────────────────────────────────────
govee:
  enabled: true
  api_key: "YOUR_GOVEE_API_KEY"
  devices:
    - name: "Bed lights"
      device_id: "YOUR_DEVICE_ID_1"
      model: "H61BE"
    - name: "TV Backlight 3 Lite"
      device_id: "YOUR_DEVICE_ID_2"
      model: "H6099"
  discovery_timeout: 3


# ─────────────────────────────────────────────────────────────────────────────
# Spotify
# ─────────────────────────────────────────────────────────────────────────────
spotify:
  enabled: true
  client_id: "YOUR_SPOTIFY_CLIENT_ID"
  client_secret: "YOUR_SPOTIFY_CLIENT_SECRET"
  redirect_uri: "http://127.0.0.1:8888/callback"
  cache_path: ".spotify_cache"


# ─────────────────────────────────────────────────────────────────────────────
# Workspace  (project scaffolding)
# ─────────────────────────────────────────────────────────────────────────────
workspace:
  path: "/Users/jtb/src/sterling/SterProjec"


# ─────────────────────────────────────────────────────────────────────────────
# Vision  (webcam + YOLO + face recognition)
# ─────────────────────────────────────────────────────────────────────────────
vision:
  enabled: true
  device_index: 0                 # USB camera index  (0 = first cam)
  yolo_model: "yolov8n.pt"        # yolov8n=fastest | yolov8s=more accurate
  face_recognition: true
  known_faces_dir: "vision/faces" # drop named JPGs here to enrol faces
  confidence_thresh: 0.45         # minimum YOLO detection confidence  (0.0–1.0)

  # Face recognition
  face_tolerance: 0.55            # matching strictness — lower = stricter  (0.4–0.6)
  face_merge_distance: 100        # pixel radius to merge a face detection with a YOLO person box

  # Expression detection
  smile_threshold: 0.04           # lip-curve ratio to flag someone as smiling  (0.02–0.08)

  # Vision-language model for real pixel understanding ("what am I holding").
  # Blank = fast YOLO + heuristics only. Enable: ollama pull moondream  then  vlm_model: "moondream"
  vlm_model: ""


# ─────────────────────────────────────────────────────────────────────────────
# Gesture detection  (disabled by default — requires vision.enabled: true)
# yolov8n-pose.pt (~7 MB) downloads automatically on first use.
# ─────────────────────────────────────────────────────────────────────────────
gestures:
  enabled: false
  poll_interval: 1.0              # seconds between gesture checks
  sustain: 1.5                    # seconds to hold gesture before it fires
  confidence: 0.45                # minimum keypoint confidence
  model: "yolov8n-pose.pt"

  # Pixel geometry for point detection (tune if your camera resolution differs)
  point_min_distance: 120         # minimum px arm extension to count as a point
  point_max_height: 80            # maximum vertical deviation for a horizontal point

  # What each gesture does
  wave_action: "wake"             # alternatives: "none"
  hands_up_action: "stop"         # alternatives: "none"
  point_right_action: "next"      # alternatives: "none"
  point_left_action: "prev"       # alternatives: "none"


# ─────────────────────────────────────────────────────────────────────────────
# Presence detection  (disabled by default — requires vision.enabled: true)
# ─────────────────────────────────────────────────────────────────────────────
presence:
  enabled: false
  check_interval: 30              # seconds between presence checks
  greet_on_enter: false           # speak greet_on_enter_message when you walk in
  lights_on_enter: false          # turn Govee lights on when person detected
  lights_off_on_leave: false      # turn lights off when room is empty
  leave_delay: 300                # seconds to wait before triggering lights-off


# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────
logging:
  level: "INFO"         # DEBUG | INFO | WARNING | ERROR
  file: "sterling.log"  # set to null to disable file logging
  console: true
